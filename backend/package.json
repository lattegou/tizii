{
  "name": "tizii-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --target node18 --out-dir dist --clean",
    "build:sea:bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/sea-entry.cjs --external:file-icon",
    "lint": "eslint src --ext .ts --fix",
    "lint:check": "eslint src --ext .ts",
    "review": "pnpm run lint:check && pnpm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.13.2",
    "chokidar": "^5.0.0",
    "croner": "^9.1.0",
    "dayjs": "^1.11.19",
    "express": "^5.1.0",
    "i18next": "^25.6.2",
    "plist": "^3.1.0",
    "webdav": "^5.8.0",
    "ws": "^8.18.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^5.0.5",
    "@types/node": "^25.0.3",
    "@types/plist": "^3.0.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
